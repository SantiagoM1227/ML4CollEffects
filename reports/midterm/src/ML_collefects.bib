@article{chance_selected_nodate,
	title = {{SELECTED} {ADVANCES} {IN} {THE} {ACCELERATOR} {DESIGN} {OF} {THE} {FUTURE} {CIRCULAR} {ELECTRON}-{POSITRON} {COLLIDER} ({FCC}-ee)},
	abstract = {In autumn 2023, the FCC Feasibility Study underwent a crucial “mid-term review”. We describe some accelerator performance risks for the proposed future circular electronpositron collider, FCC-ee, identified for, and during, the mid-term review. For the collider rings, these are the collective effects when running on the Z resonance – especially resistive wall, beam-beam, and electron cloud –, the beam lifetime, dynamic aperture, alignment tolerances, and beambased alignment. For the booster, the primary concern is the vacuum system, with regard to impedance and effects of the residual gas. For the injector, the layout and the linac repetition rate are primary considerations. We discuss the various issues and report the planned mitigations.},
	language = {en},
	author = {Chance, A and Dalena, B and Bartosik, H and Bauche, J and Buffat, X and Keintzel, J and Kersevan, R and Mether, L and Tomas, R and Vanel, A and Freeden, L Von and Zimmermann, F and Kisciny, P and Pieloni, T and Sabato, L and Wu, Y and Liuzzo, S and White, S and Gianfelice, E and Raimondi, P and Migliorati, M and Chaikovska, I and Milardi, C and Ohmi, K and Craievich, P and Koratzinos, M and Zennaro, R and Huang, X and Raubenheimer, T O and Yaman, F and Maury, H},
	file = {PDF:files/80/Chance et al. - SELECTED ADVANCES IN THE ACCELERATOR DESIGN OF THE FUTURE CIRCULAR ELECTRON-POSITRON COLLIDER (FCC-e.pdf:application/pdf},
}
